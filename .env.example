# Groq API key for natural-language parsing
GROQ_API_KEY=your_groq_api_key_here

# Flask session signing key (generate: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=replace_with_a_long_random_hex_string

# The ONLY Google account allowed to use this app
ALLOWED_EMAIL=eotoo218@gmail.com

# Google OAuth Web client ID (the client_id from your web credentials.json)
GOOGLE_CLIENT_ID=your_web_oauth_client_id.apps.googleusercontent.com

# Path to the downloaded Google "Web application" OAuth client secrets file
GOOGLE_CLIENT_SECRETS_FILE=credentials.json

# Full redirect URI registered in Google Cloud.
# Local dev: http://localhost:5000/oauth2callback
# Production: https://<your-app>.onrender.com/oauth2callback
OAUTH_REDIRECT_URI=http://localhost:5000/oauth2callback

# Set to "1" ONLY for local http development (allows OAuth over http). Unset in production.
OAUTHLIB_INSECURE_TRANSPORT=1
